# Server
SUPERTONIC_PORT=49112
SUPERTONIC_LOG_LEVEL=INFO
SUPERTONIC_STREAM_DEFAULT=true

# Model
SUPERTONIC_MODEL_NAME=supertonic-2
SUPERTONIC_MODEL_PATH=/models/supertonic2
SUPERTONIC_AUTO_DOWNLOAD=true
SUPERTONIC_DIFFUSION_STEPS=5
SUPERTONIC_DEFAULT_SPEED=1.0
SUPERTONIC_DEFAULT_LANG=en
SUPERTONIC_MAX_CHUNK_LENGTH=300
SUPERTONIC_SILENCE_DURATION=0.3

# Voices
SUPERTONIC_VOICES_DIR=./voices

# Voice style extraction (optional)
SUPERTONIC_VOICE_STYLE_CACHE_DIR=/models/voice_styles
# Example: python /app/tools/extract_style.py --input {input} --output {output}
SUPERTONIC_VOICE_EXTRACTOR_CMD=
SUPERTONIC_VOICE_EXTRACTOR_TIMEOUT=120

# Hugging Face token (optional, for faster downloads)
HF_TOKEN=
