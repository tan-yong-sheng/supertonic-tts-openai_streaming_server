# Modal app identity
SUPERTONIC_MODAL_APP=supertonic-tts

# Volumes
MODEL_VOLUME_NAME=supertonic-tts-models
# Optional: mount a voices volume at /voices
VOICES_VOLUME_NAME=supertonic-tts-voices

# Optional: Modal secret name containing AUTHENTICATION_ALLOWED_TOKENS
AUTH_SECRET_NAME=supertonic-tts-auth

# Optional: Modal secret name containing HF_TOKEN
# HF_SECRET_NAME=supertonic-tts-hf

# Optional: source path to sync voices into the voices volume
# SUPERTONIC_VOICES_SRC=/app/voices

# Optional: force a specific model path or variant
SUPERTONIC_MODEL_PATH=/models/supertonic2
SUPERTONIC_MODEL_NAME=supertonic-2
SUPERTONIC_AUTO_DOWNLOAD=true

# Optional: override voices directory in the container
# SUPERTONIC_VOICES_DIR=

# Observability
SUPERTONIC_COLDSTART_LOG=true
SUPERTONIC_REQUEST_TIMING_LOG=true
SUPERTONIC_REQUEST_TIMING_LOG_JSON=true
SUPERTONIC_TTFA_LOG=true

# Optional: disable the web UI at /
SUPERTONIC_UI_ENABLED=false

# Optional: force HuggingFace offline mode when model is cached locally
SUPERTONIC_HF_OFFLINE=true

# Optional: snapshot warmup inference (empty disables)
SUPERTONIC_WARMUP_TEXT=Hello
SUPERTONIC_WARMUP_VOICE=M1

# Limits / headers
SUPERTONIC_MAX_INPUT_CHARS=5000
SUPERTONIC_REQUEST_ID_HEADER=X-Request-ID

# Torch threading (tune per CPU)
SUPERTONIC_TORCH_THREADS=2
SUPERTONIC_TORCH_INTEROP_THREADS=1

# Chunk long inputs into smaller segments (chars). 0 disables chunking.
SUPERTONIC_CHUNK_CHARS=250
# Allow per-request override of chunk size via JSON body (chunk_chars).
SUPERTONIC_CHUNK_CHARS_ALLOW_OVERRIDE=true

# Optional: quality/speed defaults
SUPERTONIC_DIFFUSION_STEPS=5
SUPERTONIC_DEFAULT_SPEED=1.0
SUPERTONIC_DEFAULT_LANG=en
SUPERTONIC_SAMPLE_RATE=44100
SUPERTONIC_MAX_CHUNK_LENGTH=300
SUPERTONIC_SILENCE_DURATION=0.3

# Voice style extraction (optional, required for audio prompts)
SUPERTONIC_VOICE_STYLE_CACHE_DIR=/models/voice_styles
# Example: SUPERTONIC_VOICE_EXTRACTOR_CMD="python /app/tools/extract_style.py --input {input} --output {output}"
SUPERTONIC_VOICE_EXTRACTOR_CMD=
SUPERTONIC_VOICE_EXTRACTOR_TIMEOUT=120

# ONNX Runtime threading
SUPERTONIC_INTRA_OP_THREADS=2
SUPERTONIC_INTER_OP_THREADS=1

# Optional: comma-separated tokens for Bearer auth (local/dev only)
# Note: for Modal deployments, use AUTH_SECRET_NAME instead.
# AUTHENTICATION_ALLOWED_TOKENS=token1,token2
